# =============================================================================
# GBA / BBMP Ward & Engineer Platform — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# --- Supabase (client-side, safe to expose) --------------------------------
# Project URL from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable / anon key (Dashboard → Project Settings → API → Project API keys)
# Used by the browser + server components for RLS-protected reads/writes.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# --- Supabase (server-only secrets — used by scripts, NEVER shipped to client)
# Service-role key (Dashboard → Project Settings → API → service_role).
# Bypasses RLS. Used only by the seed script and admin user creation.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_jwt_xxxxxxxxxxxx

# Direct Postgres connection string for migrations + seeding.
# Dashboard → Project Settings → Database → Connection string → URI
# (use the "Session" pooler or direct connection; include your DB password).
# Example: postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- AI drafting (Phase 2) — OPTIONAL --------------------------------------
# The app works fully WITHOUT these: AI buttons show "AI not configured" and the
# manual templates still work. Keys are read ONLY from env, never the database.
# Provider: anthropic (default) | openai. Default model: claude-sonnet-4-6.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_TEMPERATURE=0.4

# --- Scheduled notifications (app/api/cron/notifications) — OPTIONAL ----------
# Point any scheduler at GET/POST /api/cron/notifications with the secret header
# (x-cron-secret) or ?secret=. It computes overdue RTIs/complaints + due
# reminders. If NOTIFY_WEBHOOK_URL is set, the digest is POSTed there (e.g. a
# Make.com webhook that fans out WhatsApp/SMS/email — same pattern as pujya_sri).
# Without these, the route returns the digest JSON and sends nothing.
CRON_SECRET=
NOTIFY_WEBHOOK_URL=

# Public base URL, used to build shareable /track/<id> status links.
SITE_URL=http://localhost:3000

# --- MCP server (mcp/bbmp-server.ts) — no extra vars needed -------------------
# The MCP server reuses NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above.
# When running from the project root (npm run mcp:start), dotenv reads .env
# automatically — no extra configuration needed.
#
# For Claude Code: create .claude/settings.json in the project root:
#   {
#     "mcpServers": {
#       "bbmp": {
#         "command": "npx",
#         "args": ["tsx", "mcp/bbmp-server.ts"],
#         "cwd": "D:/Tatvam/BBMP",
#         "env": {}
#       }
#     }
#   }
#
# For Claude Desktop: add to ~/AppData/Roaming/Claude/claude_desktop_config.json:
#   {
#     "mcpServers": {
#       "bbmp": {
#         "command": "npx",
#         "args": ["tsx", "D:/Tatvam/BBMP/mcp/bbmp-server.ts"],
#         "env": {
#           "NEXT_PUBLIC_SUPABASE_URL": "https://YOUR-PROJECT.supabase.co",
#           "SUPABASE_SERVICE_ROLE_KEY": "your-service-role-jwt"
#         }
#       }
#     }
#   }
